# ---- Server ----
NODE_ENV=development
PORT=3001
API_PREFIX=/api
TRUST_PROXY=1
REQUEST_BODY_LIMIT=1mb
LOG_LEVEL=info

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minddo_db
DB_USER=minddo_user
DB_PASSWORD=change_me
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ---- Auth ----
# IMPORTANT: replace with 64+ char random string in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ---- CORS ----
# Comma-separated list of allowed origins for browser clients
CORS_ORIGINS=http://localhost:8123,http://127.0.0.1:8123,http://localhost:5173

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ---- Seed / admin bootstrap ----
ADMIN_BOOTSTRAP_EMAIL=admin@minddo.local
ADMIN_BOOTSTRAP_PASSWORD=Admin!2026
